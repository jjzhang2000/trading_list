<Window x:Class="TradingList.WPF.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:vm="clr-namespace:TradingList.WPF.ViewModels"
        mc:Ignorable="d"
        Title="TradingList - 股票筛选系统" 
        Height="800" Width="1200"
        WindowStartupLocation="CenterScreen">
    
    <Grid Margin="10">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="200"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>
        
        <!-- 数据操作区 -->
        <GroupBox Header="数据操作" Grid.Row="0" Margin="0,0,0,10">
            <StackPanel Orientation="Horizontal" Margin="5">
                <Button Content="初始化数据库" 
                        Command="{Binding InitializeDatabaseCommand}"
                        IsEnabled="{Binding IsBusy, Converter={StaticResource InverseBooleanConverter}}"
                        Width="120" Margin="5"/>
                <Button Content="同步数据" 
                        Command="{Binding SyncDataCommand}"
                        IsEnabled="{Binding IsBusy, Converter={StaticResource InverseBooleanConverter}}"
                        Width="100" Margin="5"/>
                <Button Content="取消" 
                        Command="{Binding CancelOperationCommand}"
                        IsEnabled="{Binding IsBusy}"
                        Width="80" Margin="5"/>
                <ProgressBar Value="{Binding ProgressValue}" 
                            Width="200" Height="20" Margin="10,5"
                            IsIndeterminate="True"
                            Visibility="{Binding IsBusy, Converter={StaticResource BooleanToVisibilityConverter}}"/>
            </StackPanel>
        </GroupBox>
        
        <!-- 筛选器设置区 -->
        <GroupBox Header="筛选器设置" Grid.Row="1" Margin="0,0,0,10">
            <Grid Margin="5">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="Auto"/>
                    <ColumnDefinition Width="Auto"/>
                    <ColumnDefinition Width="Auto"/>
                    <ColumnDefinition Width="Auto"/>
                    <ColumnDefinition Width="Auto"/>
                    <ColumnDefinition Width="*"/>
                </Grid.ColumnDefinitions>
                
                <CheckBox Content="SuperTrend" 
                         IsChecked="{Binding FilterOptions.EnableSuperTrend}"
                         Grid.Column="0" Margin="5" VerticalAlignment="Center"/>
                <CheckBox Content="Vegas通道" 
                         IsChecked="{Binding FilterOptions.EnableVegas}"
                         Grid.Column="1" Margin="5" VerticalAlignment="Center"/>
                <CheckBox Content="布林带" 
                         IsChecked="{Binding FilterOptions.EnableBollingerBand}"
                         Grid.Column="2" Margin="5" VerticalAlignment="Center"/>
                <CheckBox Content="OCC" 
                         IsChecked="{Binding FilterOptions.EnableOcc}"
                         Grid.Column="3" Margin="5" VerticalAlignment="Center"/>
                <CheckBox Content="VP Slope" 
                         IsChecked="{Binding FilterOptions.EnableVpSlope}"
                         Grid.Column="4" Margin="5" VerticalAlignment="Center"/>
                
                <StackPanel Orientation="Horizontal" Grid.Column="5" HorizontalAlignment="Right">
                    <TextBlock Text="日期:" VerticalAlignment="Center" Margin="5"/>
                    <DatePicker SelectedDate="{Binding FilterOptions.Date}" 
                               Margin="5" Width="120"/>
                    <Button Content="开始筛选" 
                           Command="{Binding RunFilterCommand}"
                           IsEnabled="{Binding IsBusy, Converter={StaticResource InverseBooleanConverter}}"
                           Width="100" Margin="10,5"/>
                    <Button Content="导出CSV" 
                           Command="{Binding ExportToCsvCommand}"
                           Width="80" Margin="5"/>
                </StackPanel>
            </Grid>
        </GroupBox>
        
        <!-- 股票列表面板 -->
        <Grid Grid.Row="2" Margin="0,0,0,10">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="*"/>
                <ColumnDefinition Width="*"/>
            </Grid.ColumnDefinitions>
            
            <!-- 全部股票 -->
            <GroupBox Header="全部股票" Grid.Column="0" Margin="0,0,5,0">
                <DataGrid ItemsSource="{Binding AllStocks}" 
                         AutoGenerateColumns="False"
                         IsReadOnly="True"
                         GridLinesVisibility="Horizontal">
                    <DataGrid.Columns>
                        <DataGridTextColumn Header="代码" Binding="{Binding StockCode}" Width="80"/>
                        <DataGridTextColumn Header="名称" Binding="{Binding StockName}" Width="*"/>
                    </DataGrid.Columns>
                </DataGrid>
            </GroupBox>
            
            <!-- 筛选结果 -->
            <GroupBox Header="筛选结果" Grid.Column="1" Margin="5,0,0,0">
                <DataGrid ItemsSource="{Binding FilteredStocks}" 
                         AutoGenerateColumns="False"
                         IsReadOnly="True"
                         GridLinesVisibility="Horizontal">
                    <DataGrid.Columns>
                        <DataGridTextColumn Header="排名" Binding="{Binding Rank}" Width="50"/>
                        <DataGridTextColumn Header="代码" Binding="{Binding StockCode}" Width="80"/>
                        <DataGridTextColumn Header="名称" Binding="{Binding StockName}" Width="100"/>
                        <DataGridTextColumn Header="综合评分" Binding="{Binding StrengthScore, StringFormat=F2}" Width="80"/>
                        <DataGridTextColumn Header="强度" Binding="{Binding StrengthLabel}" Width="60"/>
                        <DataGridTextColumn Header="ST" Binding="{Binding SuperTrendScore, StringFormat=F1}" Width="50"/>
                        <DataGridTextColumn Header="Vegas" Binding="{Binding VegasScore, StringFormat=F1}" Width="60"/>
                        <DataGridTextColumn Header="BB" Binding="{Binding BollingerScore, StringFormat=F1}" Width="50"/>
                        <DataGridTextColumn Header="OCC" Binding="{Binding OccScore, StringFormat=F1}" Width="50"/>
                        <DataGridTextColumn Header="Slope" Binding="{Binding SlopeScore, StringFormat=F1}" Width="60"/>
                    </DataGrid.Columns>
                </DataGrid>
            </GroupBox>
        </Grid>
        
        <!-- 日志输出区 -->
        <GroupBox Header="日志输出" Grid.Row="3" Margin="0,0,0,10">
            <Grid>
                <TextBox Text="{Binding LogMessages, Converter={StaticResource CollectionToStringConverter}}"
                        IsReadOnly="True"
                        VerticalScrollBarVisibility="Auto"
                        TextWrapping="Wrap"
                        AcceptsReturn="True"
                        FontFamily="Consolas"
                        FontSize="12"/>
                <Button Content="清空日志" 
                       Command="{Binding ClearLogCommand}"
                       Width="80" Height="25"
                       HorizontalAlignment="Right"
                       VerticalAlignment="Top"
                       Margin="5"/>
            </Grid>
        </GroupBox>
        
        <!-- 状态栏 -->
        <StatusBar Grid.Row="4">
            <StatusBarItem>
                <TextBlock Text="{Binding StatusMessage}"/>
            </StatusBarItem>
            <StatusBarItem>
                <TextBlock Text=" | "/>
            </StatusBarItem>
            <StatusBarItem>
                <TextBlock Text="{Binding FilteredStockCount, StringFormat='筛选结果: {0} 只'}"/>
            </StatusBarItem>
        </StatusBar>
    </Grid>
</Window>
